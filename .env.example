# Required
DISCORD_TOKEN=

# Optional channel allowlist (comma-separated)
DISCORD_CHANNEL_IDS=

# Optional user / role allowlist (comma-separated ids)
DISCORD_ALLOWED_USERS=
DISCORD_ALLOWED_ROLES=

# Codex
CODEX_EXECUTABLE=codex
CODEX_WORKDIR=/data/workspace
# JSON map: {"alpha": "/data/repos/alpha", "beta": "/data/repos/beta"}
CODEX_WORKSPACES=
CODEX_DEFAULT_WORKSPACE=default
CODEX_MODEL=
CODEX_TIMEOUT_SECONDS=300
CODEX_MAX_PROMPT_CHARS=8000
CODEX_REDACT_SECRETS=1
CODEX_REQUIRE_APPROVAL=0

# Storage
CODEX_DB_PATH=/data/codex_discord.db

# Logging
LOG_LEVEL=INFO
LOG_JSON=1

# Servers
ENABLE_HEALTH=1
HEALTH_PORT=8080
ENABLE_METRICS=1
METRICS_PORT=9090
